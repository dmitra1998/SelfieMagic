# Mobile app. Use the computer's LAN IP for a physical phone, not localhost.
EXPO_PUBLIC_UPLOAD_API_URL=http://192.168.1.10:3001
EXPO_PUBLIC_MAX_RECORDING_DURATION_SECONDS=60

# Expo build configuration. Local HTTP is for development/preview only.
ALLOW_CLEARTEXT_TRAFFIC=true

# Upload API. Copy these entries into backend/.env.
AWS_REGION=ap-south-1
S3_BUCKET=selfie-magic-recordings
PORT=3001

# Optional for LocalStack or another S3-compatible service.
# AWS_ENDPOINT_URL=http://localhost:4566
# S3_FORCE_PATH_STYLE=true
