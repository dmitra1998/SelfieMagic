{
  "cli": {
    "version": ">= 20.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_UPLOAD_API_URL": "https://selfiemagic.onrender.com",
        "ALLOW_CLEARTEXT_TRAFFIC": "true"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
          "EXPO_PUBLIC_UPLOAD_API_URL": "https://selfiemagic.onrender.com",
          "ALLOW_CLEARTEXT_TRAFFIC": "false"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
